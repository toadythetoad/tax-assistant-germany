{
  "name": "steuer-assistent-2",
  "version": "2.0.0",
  "description": "Steuer Assistent 2.0 - Einkommensteuererklärung für alle Bundesländer",
  "main": "dist/main/main.js",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "build:vite": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:vite && npm run build:electron",
    "package": "npm run build && electron-builder --win --config.extraMetadata.name=steuer-assistent-2",
    "start": "electron ."
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@types/sql.js": "^1.4.11",
    "crypto-js": "^4.2.0",
    "electron-log": "^5.0.3",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^3.11.174",
    "pdfkit": "^0.14.0",
    "ppu-paddle-ocr": "^5.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.2",
    "sql.js": "^1.14.1",
    "tesseract.js": "^5.0.4",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "build": {
    "appId": "com.steuerassistent2.app",
    "productName": "Steuer Assistent 2.0",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "public/help",
        "to": "help"
      }
    ],
    "win": {
      "target": "portable",
      "signAndEditExecutable": false,
      "artifactName": "Steuer Assistent 2.0.exe"
    },
    "electronDownload": {
      "cache": "C:/Users/Kevalon/AppData/Local/electron-builder/Cache"
    }
  }
}
